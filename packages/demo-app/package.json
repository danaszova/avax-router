{
  "name": "@avalanche-dex/demo-app",
  "version": "1.0.0",
  "description": "UAT Demo App for Avalanche DEX Router Widget (npm package test mode)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cloudflare": "vite --mode cloudflare",
    "prebuild": "cd ../widget && npm run build",
    "build": "vite build --mode cloudflare",
    "preview": "vite preview --mode cloudflare",
    "use:npm": "cp package.npm.json package.json && npm install",
    "use:local": "cp package.local.json package.json && npm install"
  },
  "dependencies": {
    "@danaszova/avax-router-sdk": "^1.0.5",
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@snowmonster_defi/widget": "^1.0.4",
    "ethers": "^6.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
